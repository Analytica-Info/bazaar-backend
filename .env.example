# Server
PORT=3002
NODE_ENV=production
DOMAIN=.bazaar-uae.com
BACKEND_URL=https://app.bazaar-uae.com
FRONTEND_BASE_URL=https://www.bazaar-uae.com
URL=https://www.bazaar-uae.com
ENVIRONMENT=false

# Database
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>

# JWT
JWT_SECRET=<generate-secure-random-string>
JWT_REFRESH_SECRET=<generate-secure-random-string>

# CORS — web domains that can call this API
# Mobile apps send no origin header — allowed automatically
# Add all web frontend domains (storefront, admin, test variants)
ALLOWED_ORIGINS=https://www.bazaar-uae.com,https://admin.bazaar-uae.com,https://test.bazaar-uae.com,https://test-admin.bazaar-uae.com

# OAuth - Google
GOOGLE_CLIENT_ID=<web-google-client-id>
ANDROID_GOOGLE_CLIENT_ID=<android-google-client-id>
IOS_GOOGLE_CLIENT_ID=<ios-google-client-id>

# OAuth - Apple
APPLE_CLIENT_ID=<apple-client-id>
APPLE_TEAM_ID=<apple-team-id>
APPLE_KEY_ID=<apple-key-id>
APPLE_PRIVATE_KEY=<apple-private-key>

# Payments - Stripe
STRIPE_SK=<stripe-secret-key>
STRIPE_WEBHOOK_SECRET=whsec_...

# Payments - Tabby
TABBY_AUTH_KEY=<tabby-auth-key>
TABBY_MERCHENT_CODE=<tabby-merchant-code>
TABBY_SECRET_KEY=<tabby-secret-key>
TABBY_WEBHOOK_SECRET=<tabby-webhook-secret>
TABBY_IPS=<comma-separated-tabby-ips>

# Email (SMTP)
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=587
EMAIL_USERNAME=<email-address>
EMAIL_PASSWORD=<email-password>
ADMIN_EMAIL=<admin-email>
CC_MAILS=<comma-separated-cc-emails>

# Email Validation
VERIEMAIL_API_KEY=<verimail-api-key>

# Lightspeed POS
API_KEY=<lightspeed-api-key>
CATEGORIES_URL=https://bazaargeneraltrading.retail.lightspeed.app/api/2.0/product_categories
PRODUCTS_URL=https://bazaargeneraltrading.retail.lightspeed.app/api/3.0/products?page_size=2000
PRODUCTS_UPDATE=https://bazaargeneraltrading.retail.lightspeed.app/api/2.1/products
PRODUCT_TYPE=https://bazaargeneraltrading.retail.lightspeed.app/api/2.0/product_types
BRANDS_URL=<lightspeed-brands-url>

# Google Sheets
SPREADSHEET_ID=<google-spreadsheet-id>

# FTP
FTP_HOST=<ftp-host>
FTP_USER=<ftp-user>
FTP_PASSWORD=<ftp-password>
FTP_SECURE=false

# Nomod Payment
NOMOD_API_KEY=
# Base URL for Nomod HTTPS redirect interception in the mobile WebView.
# Mobile's NavigationDelegate intercepts any URL matching this host+path prefix.
NOMOD_RETURN_URL_BASE=https://app.bazaar-uae.com/payments/nomod/return
# Payment provider selection: default stripe; per-request selection used at runtime (stripe | nomod)
PAYMENT_PROVIDER=stripe
# NOTE: NOMOD_ENABLED env var was retired. Nomod's live toggle is now
# the DB-backed `paymentMethodConfig.nomodEnabled` admin-toggleable flag
# (PATCH /v2/admin/payment-method-config). NOMOD_API_KEY (above) is still
# the provisioning gate — credential must be present for the v2 client
# to see Nomod regardless of the DB toggle.

# Mobile App Version Gate
# Semver minimum version that the mobile app must meet; older versions are prompted to update
MIN_SUPPORTED_MOBILE_VERSION=1.0.35

# ── Tunable runtime config (all optional; defaults shown) ────────────────────

# Cache TTLs (seconds) — safe to increase for better performance, decrease for fresher data
CACHE_TTL_SMART_CATEGORY=300       # smart categories (trending, today-deal, flash-sale, etc.)
CACHE_TTL_CATEGORIES=300           # product sidebar categories
CACHE_TTL_ALL_CATEGORIES=300       # all-categories nav list
CACHE_TTL_HOME_PRODUCTS=300        # home-page product grid
CACHE_TTL_LS_INVENTORY=300         # Lightspeed inventory snapshot
CACHE_TTL_LS_PRODUCTS=600          # Lightspeed full product list
CACHE_TTL_LS_CATEGORIES=3600       # Lightspeed category list (changes rarely)
CACHE_TTL_PRODUCTS_BY_VARIANT=300  # mobile products-by-variant color grouping
CACHE_TTL_PRODUCT_TYPE=1800        # Lightspeed product-type / category detail
CACHE_TTL_MAX_DISCOUNT=21600       # global max-discount metric (6 hours)
CACHE_TTL_WEBHOOK_DEDUP=3          # webhook dedup lock — keep very short
CACHE_TTL_METRICS_COUNTER=10800    # Redis metrics counters (3 hours)
CACHE_TTL_ERROR_LOG=86400          # error-log Redis list TTL (24 hours)

# Auth expiry windows
OTP_EXPIRY_MINUTES=15              # recovery-code / OTP validity window
RESET_TOKEN_EXPIRY_MINUTES=10      # password-reset token validity
RECOVERY_RESEND_WINDOW_HOURS=24    # sliding window for recovery-code resend rate-limit

# JWT token expiry strings (jsonwebtoken format — e.g. '1h', '7d', '15m')
JWT_ACCESS_EXPIRY=1h               # access token lifetime (login + checkAccessToken re-issue)
JWT_ACCESS_REFRESH_EXPIRY=2m       # access token lifetime issued by /refresh (intentionally short for rotation security — see BUGS.md BUG-035)
JWT_REFRESH_EXPIRY=7d              # refresh token lifetime (all issuance paths)
JWT_ADMIN_EXPIRY=7d                # admin session token lifetime
JWT_RESET_CODE_EXPIRY=10m          # short-lived code token for password-reset flow

# Cookie max-age (days)
SESSION_COOKIE_DAYS=7              # standard session (mobile + web without remember-me)
REMEMBER_ME_COOKIE_DAYS=30         # "remember me" session
WEB_COOKIE_DAYS=1                  # web-only short session (Google/Apple login fallback)

# Rate limiting
RATE_LIMIT_AUTH_WINDOW_MINUTES=15  # auth endpoint rate-limit window
RATE_LIMIT_AUTH_MAX=20             # max auth attempts per window
RATE_LIMIT_PWD_RESET_WINDOW_MINUTES=15  # password-reset rate-limit window
RATE_LIMIT_PWD_RESET_MAX=5         # max password-reset attempts per window

# Order / fulfilment
DELIVERY_DAYS=3                    # calendar days added to order date for estimated delivery
PENDING_PAYMENT_EXPIRY_MINUTES=30  # how long a pending-payment document lives before TTL expiry

# External API timeouts (ms)
NOMOD_TIMEOUT_MS=30000             # Nomod checkout API request timeout

# Mobile version gate (BUG-052)
# Read by src/middleware/versionGate.js
MIN_SUPPORTED_MOBILE_VERSION=1.0.0        # minimum app version; requests below this → 426 (when enforcement on)
MIN_SUPPORTED_MOBILE_VERSION_ENFORCE=false # set to 'true' to actively reject stale versions (default false = observe-only)
IOS_UPDATE_URL=https://apps.apple.com/app/bazaar/id0000000000      # deep-link returned in 426 body for iOS clients
ANDROID_UPDATE_URL=https://play.google.com/store/apps/details?id=com.bazaar.app  # deep-link for Android clients


# Payment reconciler (Nomod has no webhooks — polling is the only recovery path)
# Disabled by default. Set to 'true' to enable the background cron job.
RECONCILER_ENABLED=false
RECONCILER_INTERVAL_MINUTES=5       # how often to poll (minutes)
RECONCILER_LOOKBACK_MINUTES=60      # only scan records created within this window
RECONCILER_BATCH_SIZE=50            # max records processed per tick
RECONCILER_LOCK_TTL_SECONDS=240     # Redis distributed-lock TTL; keep < intervalMs

# Nomod staging amount override — TRIPLE-GATED, never active in production.
# Set ALL THREE to enable a fixed-amount override for staging Nomod testing
# (Nomod has no sandbox; this lets you test without burning real money).
# Production safety: NODE_ENV=production unconditionally disables the override.
# Gate 1 — explicit opt-in: ONLY the literal string 'true' activates this flag.
#           'false', '1', 'yes', 'TRUE' are all treated as inactive.
NOMOD_ALLOW_AMOUNT_OVERRIDE=false
# Gate 2 — (NODE_ENV is set elsewhere — staging values must be != 'production')
# Gate 3 — the fixed amount to charge; must be a positive finite number.
NOMOD_STAGING_AMOUNT_OVERRIDE_AED=1

# Cart v2 gift engine (Wave 2A)
# Set to 'true' in staging after running scripts/seed/cart-threshold-gift-v2.js
CART_GIFT_V2_ENABLED=false
