# Server
PORT=5000
NODE_ENV=production
DOMAIN=bazaar-uae.com
BACKEND_URL=https://api.bazaar-uae.com
FRONTEND_BASE_URL=https://www.bazaar-uae.com
URL=https://www.bazaar-uae.com
ENVIRONMENT=false

# Database
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>

# JWT
JWT_SECRET=<generate-secure-random-string>
JWT_REFRESH_SECRET=<generate-secure-random-string>

# CORS
ALLOWED_ORIGINS=https://www.bazaar-uae.com,https://admin.bazaar-uae.com

# OAuth - Google
GOOGLE_CLIENT_ID=<web-google-client-id>
ANDROID_GOOGLE_CLIENT_ID=<android-google-client-id>
IOS_GOOGLE_CLIENT_ID=<ios-google-client-id>

# OAuth - Apple
APPLE_CLIENT_ID=<apple-client-id>
APPLE_TEAM_ID=<apple-team-id>
APPLE_KEY_ID=<apple-key-id>
APPLE_PRIVATE_KEY=<apple-private-key>

# Payments - Stripe
STRIPE_SK=<stripe-secret-key>

# Payments - Tabby
TABBY_AUTH_KEY=<tabby-auth-key>
TABBY_MERCHENT_CODE=<tabby-merchant-code>
TABBY_SECRET_KEY=<tabby-secret-key>
TABBY_WEBHOOK_SECRET=<tabby-webhook-secret>
TABBY_IPS=<comma-separated-tabby-ips>

# Email (SMTP)
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=587
EMAIL_USERNAME=<email-address>
EMAIL_PASSWORD=<email-password>
ADMIN_EMAIL=<admin-email>
CC_MAILS=<comma-separated-cc-emails>

# Email Validation
VERIEMAIL_API_KEY=<verimail-api-key>

# Lightspeed POS
API_KEY=<lightspeed-api-key>
CATEGORIES_URL=https://bazaargeneraltrading.retail.lightspeed.app/api/2.0/product_categories
PRODUCTS_URL=https://bazaargeneraltrading.retail.lightspeed.app/api/3.0/products?page_size=2000
PRODUCTS_UPDATE=https://bazaargeneraltrading.retail.lightspeed.app/api/2.1/products
PRODUCT_TYPE=https://bazaargeneraltrading.retail.lightspeed.app/api/2.0/product_types
BRANDS_URL=<lightspeed-brands-url>

# Google Sheets
SPREADSHEET_ID=<google-spreadsheet-id>

# FTP
FTP_HOST=<ftp-host>
FTP_USER=<ftp-user>
FTP_PASSWORD=<ftp-password>
FTP_SECURE=false
